<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="siwap"
        Arguments=""
        InstallLocation="C:\Program Files\Siwap\Siwap">
    </Installer>
    <PackageInformation
        PackageName="Siwap"
        PackageDisplayName="Siwap"
        PublisherName="CN=Siwap"
        PublisherDisplayName="Siwap"
        Version="0.1.0.0"
        PackageDescription="Project-based AI assistant session launcher">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="app.siwap.desktop"
                Description="Project-based AI assistant session launcher"
                DisplayName="Siwap"
                ExecutableName="siwap"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Siwap</DisplayName>
            <PublisherDisplayName>Siwap</PublisherDisplayName>
            <Description>Project-based AI assistant session launcher</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="siwap.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
